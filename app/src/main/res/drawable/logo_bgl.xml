<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="140dp"
    android:height="140dp"
    android:viewportWidth="140"
    android:viewportHeight="140">

    <!-- Outer glass halo -->
    <path
        android:pathData="M70,70m-68,0a68,68 0,1 1,136 0a68,68 0,1 1,-136 0"
        android:fillColor="#1AFFFFFF" />

    <!-- Gold outer ring -->
    <path
        android:pathData="M70,70m-58,0a58,58 0,1 1,116 0a58,58 0,1 1,-116 0"
        android:strokeColor="#F6D98A"
        android:strokeWidth="3"
        android:fillColor="#00000000" />

    <!-- Navy glass body -->
    <path
        android:pathData="M70,70m-50,0a50,50 0,1 1,100 0a50,50 0,1 1,-100 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="30" android:startY="20"
                android:endX="110" android:endY="120">
                <item android:offset="0" android:color="#FF24326B" />
                <item android:offset="1" android:color="#FF0C1230" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner gold aperture ring -->
    <path
        android:pathData="M70,70m-38,0a38,38 0,1 1,76 0a38,38 0,1 1,-76 0"
        android:strokeColor="#80E9C46A"
        android:strokeWidth="1.5"
        android:fillColor="#00000000" />

    <!-- Aperture blades (camera iris motif) -->
    <path android:pathData="M70,34 L92,52 L70,70 Z" android:fillColor="#33F6D98A" />
    <path android:pathData="M106,70 L84,88 L70,70 Z" android:fillColor="#26E9C46A" />
    <path android:pathData="M70,106 L48,88 L70,70 Z" android:fillColor="#33F6D98A" />
    <path android:pathData="M34,70 L56,52 L70,70 Z" android:fillColor="#26E9C46A" />

    <!-- Top glossy highlight -->
    <path
        android:pathData="M44,40 Q70,28 96,40 Q70,52 44,40 Z"
        android:fillColor="#40FFFFFF" />
</vector>
