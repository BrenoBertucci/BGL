<?xml version="1.0" encoding="utf-8"?>
<!-- Tela de Detalhes (UC04). -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/detalhes_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cinematic"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".DetalhesActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">

        <!-- Header: voltar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/glass_circle"
                android:contentDescription="@string/action_back"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:letterSpacing="0.08"
                android:text="@string/title_detalhes"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Pôster em destaque -->
        <ImageView
            android:id="@+id/img_poster"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:background="@drawable/glass_input"
            android:contentDescription="@string/brand_name"
            android:scaleType="centerCrop" />

        <!-- Título -->
        <TextView
            android:id="@+id/txt_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Ano + nota -->
        <TextView
            android:id="@+id/txt_ano_nota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/gold"
            android:textSize="15sp" />

        <!-- Sinopse -->
        <TextView
            android:id="@+id/txt_sinopse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <!-- Elenco -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/label_elenco"
            android:textColor="@color/gold"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_elenco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <!-- Botões de ação (UC05, UC06, UC07) -->
        <Button
            android:id="@+id/btn_favoritar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/glass_button_ripple"
            android:stateListAnimator="@null"
            android:text="@string/action_favoritar"
            android:textColor="@color/navy_deep"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_assistindo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/glass_input_ripple"
            android:stateListAnimator="@null"
            android:text="@string/action_assistindo"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_watchlist"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/glass_input_ripple"
            android:stateListAnimator="@null"
            android:text="@string/action_watchlist"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
        <Button
            android:id="@+id/btn_diario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Diário Privado"
            android:drawableStart="@android:drawable/ic_secure" />
    </LinearLayout>
</ScrollView>
