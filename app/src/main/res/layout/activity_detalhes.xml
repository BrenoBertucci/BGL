<?xml version="1.0" encoding="utf-8"?>
<!-- Tela de Detalhes (UC04). -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/detalhes_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cinematic"
    android:fillViewport="true"
    tools:context=".DetalhesActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Pôster em destaque -->
        <ImageView
            android:id="@+id/img_poster"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:contentDescription="@string/brand_name"
            android:scaleType="centerCrop"
            android:background="@drawable/glass_input" />

        <!-- Título -->
        <TextView
            android:id="@+id/txt_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Ano + nota -->
        <TextView
            android:id="@+id/txt_ano_nota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/gold"
            android:textSize="15sp" />

        <!-- Sinopse -->
        <TextView
            android:id="@+id/txt_sinopse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp" />

        <!-- Elenco -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Elenco"
            android:textColor="@color/gold"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_elenco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp" />

        <!-- Botões de ação (UC05, UC06, UC07) -->
        <Button
            android:id="@+id/btn_favoritar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/glass_button_ripple"
            android:stateListAnimator="@null"
            android:text="Favoritar"
            android:textColor="@color/navy_deep"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_assistindo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/glass_input"
            android:text="Assistindo"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_watchlist"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/glass_input"
            android:text="Assistir Mais Tarde"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>
</ScrollView>
