<?xml version="1.0" encoding="utf-8"?>
<!-- Tela de Menu (hub): leva para as 4 telas do app. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/menu_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cinematic"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".MenuActivity">

    <LinearLayout
        android:id="@+id/menu_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/img_logo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="24dp"
            android:contentDescription="@string/brand_name"
            android:src="@drawable/logo_bgl" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:letterSpacing="0.22"
            android:shadowColor="#80E9C46A"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="18"
            android:text="@string/brand_name"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Botões de navegação -->
        <Button
            android:id="@+id/btn_buscar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/glass_button_ripple"
            android:stateListAnimator="@null"
            android:text="@string/menu_buscar"
            android:textColor="@color/navy_deep"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_favoritos"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/glass_input_ripple"
            android:stateListAnimator="@null"
            android:text="@string/title_favoritos"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_assistindo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/glass_input_ripple"
            android:stateListAnimator="@null"
            android:text="@string/title_assistindo"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_watchlist"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/glass_input_ripple"
            android:stateListAnimator="@null"
            android:text="@string/title_watchlist"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="32dp"
            android:background="@android:color/transparent"
            android:text="@string/action_logout"
            android:textColor="@color/gold"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
