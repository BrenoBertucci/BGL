<?xml version="1.0" encoding="utf-8"?>
<!-- Cada item da lista surge caindo suavemente com fade. -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:interpolator/decelerate_cubic"
    android:duration="380">
    <translate android:fromYDelta="14%" android:toYDelta="0" />
    <alpha android:fromAlpha="0" android:toAlpha="1" />
    <scale
        android:fromXScale="0.96" android:toXScale="1"
        android:fromYScale="0.96" android:toYScale="1"
        android:pivotX="50%" android:pivotY="50%" />
</set>
